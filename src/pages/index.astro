---
import Base from "@/layouts/Base.astro";
---

<Base>
  <main>
    <section class="hero">
      <h1 data-animate="font-weight">
        <span>Maxed out in detail</span>
        <span>—</span>
        <span>minimal in form</span>
      </h1>
      <h2>
        <span>UX</span>
        <span>UI</span>
        <span>PRODUCT</span>
        <span>DESIGNER</span>
      </h2>
    </section>
  </main>
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    height: var(--hero-h);

    h1 {
      font-size: clamp(1rem, 5cqw, 4.5rem);
      line-height: 1;
      white-space: nowrap;
      letter-spacing: 0.02em;
      width: 100%;
      max-width: 1200px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    h2 {
      font-size: 0.75rem;
      line-height: 1;
      color: var(--color-text-secondary);
      width: 100%;
      max-width: 1200px;
      display: flex;
      justify-content: space-between;
      font-family: 'Geist Mono', monospace;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
  }

  @media (max-width: 767px) {
    .hero h1 {
      font-size: clamp(1rem, 10cqw, 4.5rem);
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;

      span:nth-child(2) {
        display: none;
      }
    }
  }
</style>
